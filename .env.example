# ============================================
# CRM VENDAS - Configuração do Ambiente
# ============================================
# Copie este arquivo para .env e preencha com suas chaves do Supabase
# NÃOコミtar este arquivo no git!

# -----------------------------------------------------
# SUPABASE - Obtendo as chaves:
# 1. Acesse https://supabase.com/dashboard
# 2. Selecione seu projeto
# 3. Vá em Project Settings > API
# -----------------------------------------------------

# URL do projeto (Project Settings > General > Project URL)
SUPABASE_URL=https://sbp_ba6ef2263923491b7c91765c66b9a97a65eae983.supabase.co

# Chave anônima pública (Project Settings > API > "anon public")
SUPABASE_ANON_KEY=SUA_ANON_KEY_AQUI

# Chave de serviço (Project Settings > API > "service_role" > clique em Reveal)
# ATENÇÃO: Esta chave tem acesso admin ao banco. NUNCA use no frontend!
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY_AQUI

# -----------------------------------------------------
# Configuração do Servidor
# -----------------------------------------------------
PORT=3000
NODE_ENV=production

# -----------------------------------------------------
# JWT Secret
# Gere uma chave forte em: https://generate-secret.vercel.app/32
# -----------------------------------------------------
JWT_SECRET=sua-chave-jwt-secreta-aqui-mude-em-producao-minimo-32-caracteres