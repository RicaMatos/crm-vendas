# ============================================
# CRM VENDAS - Configuração de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores

# -----------------------------------------------------
# SUPABASE - Obtenha em: https://supabase.com/dashboard/project/<seu-projeto>/settings/api
# -----------------------------------------------------

# URL do projeto Supabase
SUPABASE_URL=https://xxxxx.supabase.co

# Chave anônima pública (Public anon key)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave de serviço (Service role key) - NUNCA exponha no frontend!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------
# Configuração do Servidor
# -----------------------------------------------------
PORT=3000
NODE_ENV=production

# -----------------------------------------------------
# JWT Secret - Gere uma chave segura única
# -----------------------------------------------------
JWT_SECRET=gere_uma_chave_jwt_segura_aqui

# -----------------------------------------------------
# Google Gemini AI - Obtenha em: https://aistudio.google.com/apikey
# -----------------------------------------------------
GEMINI_API_KEY=sua_chave_gemini_aqui

# -----------------------------------------------------
# Configurações de Segurança
# -----------------------------------------------------

# Email do administrador principal (usado para atribuir permissões de admin)
ADMIN_EMAIL=admin@crm.com

# -----------------------------------------------------
# CORS - Origins permitidas (separadas por vírgula)
# -----------------------------------------------------
ALLOWED_ORIGINS=https://seudominio.com,https://www.seudominio.com